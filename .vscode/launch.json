{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Producer",
      "type": "debugpy",
      "request": "launch",
      "module": "kafka_producer.main",
      "python": "${workspaceFolder}\\kafka_producer\\.venv\\Scripts\\python",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug Consumer",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}\\spark_streaming\\main.py",
      "python": "${workspaceFolder}\\spark_streaming\\.venv\\Scripts\\python",
      "cwd": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Producer/Consumer",
      "configurations": ["Debug Producer", "Debug Consumer"],
      "stopAll": true
    }
  ]
}
